{
  "name": "docflow-pro",
  "version": "0.1.0",
  "main": "dist-electron/main/index.js",
  "description": "DocFlow Pro - Offline desktop utility suite.",
  "author": "DocFlow Pro",
  "license": "MIT",
  "private": true,
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:7777/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win nsis portable",
    "build:appx": "tsc && vite build && electron-builder --win appx",
    "preview": "vite preview",
    "pretest": "vite build --mode=test",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "adm-zip": "^0.5.16",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "pdf-lib": "^1.17.1",
    "react-router-dom": "^7.13.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.24",
    "electron": "^33.2.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.5"
  }
}
